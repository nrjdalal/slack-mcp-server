# better-slack-mcp reads its Slack user token from the environment at runtime.
# With inscope, the chpwd hook exports this per workspace ($PWD); otherwise set it yourself.

# User OAuth token (xoxp-...). Create the app from manifest.full.yaml or
# manifest.readonly.yaml, install it, and copy the "User OAuth Token".
SLACK_MCP_XOXP_TOKEN=

# Optional: enable write tools (off by default). Truthy = "true" or "1".
# When unset/false the server exposes only the read-only tools.
# SLACK_MCP_ALLOW_WRITE=true
