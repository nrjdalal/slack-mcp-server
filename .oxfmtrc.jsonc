{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "experimentalSortImports": {},
  "experimentalTailwindcss": {},
  // generated artifacts are owned by their generators (scripts/gen-*.ts), not the formatter
  "ignorePatterns": [
    "**/*.lock",
    ".agents/**",
    ".claude/**",
    "README.md",
    "docs/coverage.md",
    "scripts/slack-methods.json",
  ],
}
