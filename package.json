{
  "name": "better-slack-mcp",
  "version": "0.0.0",
  "private": true,
  "description": "Better Slack MCP server (user token / xoxp): a superset of korotovsky/slack-mcp-server and Slack's hosted connector",
  "keywords": [
    "claude",
    "cli",
    "mcp",
    "model-context-protocol",
    "slack",
    "xoxp"
  ],
  "homepage": "https://github.com/nrjdalal/better-slack-mcp#readme",
  "bugs": "https://github.com/nrjdalal/better-slack-mcp/issues",
  "license": "MIT",
  "author": {
    "name": "Neeraj Dalal",
    "email": "admin@nrjdalal.com",
    "url": "https://nrjdalal.com"
  },
  "repository": "nrjdalal/better-slack-mcp",
  "funding": "https://github.com/sponsors/nrjdalal",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev": "turbo run dev",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "prepare": "bunx lefthook install"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "changelogen": "catalog:",
    "lefthook": "catalog:",
    "lint-staged": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "turbo": "catalog:"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "packageManager": "bun@1.3.10",
  "catalog": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.0",
    "@typescript/native-preview": "^7.0.0-dev.20260519.1",
    "changelogen": "0.6.2",
    "lefthook": "^2.1.8",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "tsdown": "^0.21.10",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  }
