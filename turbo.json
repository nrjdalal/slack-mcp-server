{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "check-types": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },
    "test": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/manifest.full.yaml",
        "$TURBO_ROOT$/manifest.readonly.yaml"
      ]
    }
  },
  "globalEnv": ["SKIP_ENV_VALIDATION", "NODE_ENV"]
}
